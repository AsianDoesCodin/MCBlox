{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "McBlox",
  "version": "0.4.2",
  "identifier": "com.mcblox.launcher",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "McBlox",
        "width": 1100,
        "height": 700,
        "minWidth": 800,
        "minHeight": 500
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "resources/mods/mcblox-mod-forge.jar": "mods/mcblox-mod-forge.jar",
      "resources/mods/mcblox-mod-forge-1.12.jar": "mods/mcblox-mod-forge-1.12.jar",
      "resources/mods/mcblox-mod-forge-1.16.jar": "mods/mcblox-mod-forge-1.16.jar",
      "resources/mods/mcblox-mod-forge-1.18.jar": "mods/mcblox-mod-forge-1.18.jar",
      "resources/mods/mcblox-mod-fabric.jar": "mods/mcblox-mod-fabric.jar"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": "v1Compatible"
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDc3RUIyRTYyOEEzMzhEOTYKUldTV2pUT0tZaTdyZDhERjgzbEMzVTJya0FkQzZvUmlqZW0ySE9ZQU9vYkdaRG9vWlN4cWFlb0oK",
      "endpoints": [
        "https://github.com/AsianDoesCodin/MCBlox/releases/latest/download/latest.json"
      ]
    }
  }
}
